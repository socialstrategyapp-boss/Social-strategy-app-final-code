# .env.example — Environment Variables Reference

# ============================================================
# COPY THIS FILE TO .dev.vars FOR LOCAL DEVELOPMENT
# NEVER COMMIT .dev.vars OR .env TO GIT
# ============================================================

# ---- Database ----------------------------------------------
# Cloudflare D1 database binding (configured in wrangler.jsonc)
# DB binding is automatic — no env var needed for D1

# ---- OpenAI ------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here

# ---- Stripe ------------------------------------------------
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
STRIPE_PRICE_BUSINESS=price_your-business-plan-price-id
STRIPE_PRICE_PRO=price_your-pro-plan-price-id
STRIPE_PRICE_ENTERPRISE=price_your-enterprise-plan-price-id
STRIPE_PRICE_STARTER_PACK=price_your-starter-credit-pack-id
STRIPE_PRICE_GROWTH_PACK=price_your-growth-credit-pack-id
STRIPE_PRICE_SCALE_PACK=price_your-scale-credit-pack-id
STRIPE_PRICE_AGENCY_PACK=price_your-agency-credit-pack-id

# ---- Admin -------------------------------------------------
ADMIN_TOKEN=your-secure-admin-token-here-min-32-chars

# ---- GitHub Archival (Optional) ----------------------------
GITHUB_TOKEN=ghp_your-github-personal-access-token
GITHUB_REPO_OWNER=your-github-org-or-username
GITHUB_REPO_NAME=Social-strategy-app-final-code

# ---- Social Platform APIs ----------------------------------

# Instagram / Facebook (Meta)
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# TikTok
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret

# LinkedIn
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# YouTube (Google)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Pinterest
PINTEREST_APP_ID=your-pinterest-app-id
PINTEREST_APP_SECRET=your-pinterest-app-secret

# Twitter / X
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret

# Threads (uses Meta credentials)
# THREADS_APP_ID same as META_APP_ID

# ---- Demo Mode (Set to 'true' to skip OpenAI calls) --------
DEMO_MODE=false

# ---- App Config --------------------------------------------
APP_URL=https://your-app.pages.dev
APP_ENV=production  # development | staging | production

# ---- Cloudflare R2 (if using R2 for media storage) ---------
# R2 binding is automatic — configured in wrangler.jsonc

# ---- Cloudflare KV (if using KV for caching) ---------------
# KV binding is automatic — configured in wrangler.jsonc
